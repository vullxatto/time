// ER-диаграмма (схема БД SQLite)
// Рендер: dot -Tpng er_diagram.dot -o er_diagram.png

digraph ER {
    rankdir=LR;
    fontname="Helvetica";
    node [shape=plaintext, fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];

    // -------- основные сущности --------
    client [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#fff3cd"><B>client</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B>  INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">surname  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">name     TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">secname  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">address  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">phone    TEXT</TD></TR>
        </TABLE>>];

    routes [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#fff3cd"><B>routes</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B>     INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">name     TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">climate  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">duration INTEGER</TD></TR>
          <TR><TD ALIGN="LEFT">hotel    TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">cost     INTEGER</TD></TR>
        </TABLE>>];

    package [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD COLSPAN="2" BGCOLOR="#fff3cd"><B>package</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B></TD>             <TD ALIGN="LEFT">INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">date</TD>             <TD ALIGN="LEFT">TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">quantity</TD>         <TD ALIGN="LEFT">INTEGER</TD></TR>
          <TR><TD ALIGN="LEFT">discount</TD>         <TD ALIGN="LEFT">INTEGER</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="ac">airline_code</TD>     <TD ALIGN="LEFT">INTEGER FK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="oc">touroperator_code</TD><TD ALIGN="LEFT">INTEGER FK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="mc">manager_code</TD>     <TD ALIGN="LEFT">INTEGER FK</TD></TR>
        </TABLE>>];

    package_client [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD COLSPAN="2" BGCOLOR="#e8e8e8"><B>package_client</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B></TD>    <TD ALIGN="LEFT">INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="p">package</TD> <TD ALIGN="LEFT">INTEGER FK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="c">client</TD>  <TD ALIGN="LEFT">INTEGER FK</TD></TR>
        </TABLE>>];

    package_route [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD COLSPAN="2" BGCOLOR="#e8e8e8"><B>package_route</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B></TD>    <TD ALIGN="LEFT">INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="p">package</TD> <TD ALIGN="LEFT">INTEGER FK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="r">routes</TD>  <TD ALIGN="LEFT">INTEGER FK</TD></TR>
        </TABLE>>];

    airline [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#d1e7dd"><B>airline</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B>        INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">name        TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">flight_cost INTEGER</TD></TR>
        </TABLE>>];

    touroperator [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#d1e7dd"><B>touroperator</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B>    INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">name    TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">address TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">phone   TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">website TEXT</TD></TR>
        </TABLE>>];

    manager [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#d1e7dd"><B>manager</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B>     INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT">surname  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">name     TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">secname  TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">position TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">phone    TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">email    TEXT</TD></TR>
        </TABLE>>];

    payment [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD COLSPAN="2" BGCOLOR="#d1e7dd"><B>payment</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>code</B></TD>            <TD ALIGN="LEFT">INTEGER  PK</TD></TR>
          <TR><TD ALIGN="LEFT" PORT="p">package_code</TD>  <TD ALIGN="LEFT">INTEGER FK UNIQUE</TD></TR>
          <TR><TD ALIGN="LEFT">date</TD>     <TD ALIGN="LEFT">TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">amount</TD>   <TD ALIGN="LEFT">INTEGER</TD></TR>
          <TR><TD ALIGN="LEFT">method</TD>   <TD ALIGN="LEFT">TEXT</TD></TR>
          <TR><TD ALIGN="LEFT">status</TD>   <TD ALIGN="LEFT">TEXT</TD></TR>
        </TABLE>>];

    // -------- связи --------
    // M:N через таблицы-связки
    package_client:p -> package [arrowhead=crow, arrowtail=tee, dir=both];
    package_client:c -> client  [arrowhead=crow, arrowtail=tee, dir=both];
    package_route:p  -> package [arrowhead=crow, arrowtail=tee, dir=both];
    package_route:r  -> routes  [arrowhead=crow, arrowtail=tee, dir=both];

    // FK 1:N от package
    package:ac -> airline      [arrowhead=tee, arrowtail=crow, dir=both, label="N:1"];
    package:oc -> touroperator [arrowhead=tee, arrowtail=crow, dir=both, label="N:1"];
    package:mc -> manager      [arrowhead=tee, arrowtail=crow, dir=both, label="N:1"];

    // 1:1 платёж — путёвка
    payment:p -> package [arrowhead=tee, arrowtail=tee, dir=both, label="1:1"];
}
