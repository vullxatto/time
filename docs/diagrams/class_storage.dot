// Структура хранения: коллекции и агрегатор TravelCompany
// Рендер: dot -Tpng class_storage.dot -o class_storage.png

digraph Storage {
    rankdir=BT;
    fontname="Helvetica";
    node [shape=plaintext, fontname="Helvetica", fontsize=10];
    edge [fontname="Helvetica", fontsize=9];

    entityList [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#e8e8e8"><B>entityList</B></TD></TR>
          <TR><TD ALIGN="LEFT">- list: list[entity]<BR ALIGN="LEFT"/></TD></TR>
          <TR><TD ALIGN="LEFT">+ findByCode(code) : entity<BR ALIGN="LEFT"/>+ getNewCode() : int<BR ALIGN="LEFT"/>+ getCodes() : list<BR ALIGN="LEFT"/>+ getItems() : list<BR ALIGN="LEFT"/>+ appendItem(value)<BR ALIGN="LEFT"/>+ removeItem(value)<BR ALIGN="LEFT"/>+ clear()<BR ALIGN="LEFT"/></TD></TR>
        </TABLE>>];

    clientList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#fff3cd"><B>clientList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    routeList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#fff3cd"><B>routeList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    travelList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#fff3cd"><B>travelList</B></TD></TR>
        <TR><TD ALIGN="LEFT">- _parent_library<BR ALIGN="LEFT"/></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    airlineList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#d1e7dd"><B>airlineList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    touroperatorList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#d1e7dd"><B>touroperatorList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    managerList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#d1e7dd"><B>managerList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    paymentList [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#d1e7dd"><B>paymentList</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(...)<BR ALIGN="LEFT"/>+ newItem(...)<BR ALIGN="LEFT"/>+ findByPackage(code) : payment<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    travelList_ext [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#cfe2ff"><B>travelList_ext</B></TD></TR>
        <TR><TD ALIGN="LEFT">+ createItem(..., airline, touroperator, manager)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];

    TravelCompany [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#f8d7da"><B>TravelCompany</B></TD></TR>
          <TR><TD ALIGN="LEFT">- clientList: clientList<BR ALIGN="LEFT"/>- routeList: routeList<BR ALIGN="LEFT"/>- travelList: travelList<BR ALIGN="LEFT"/></TD></TR>
          <TR><TD ALIGN="LEFT">+ createClient/Route/Travel(...)<BR ALIGN="LEFT"/>+ removeClient/Route/Travel(...)<BR ALIGN="LEFT"/>+ getClient/Route/Travel(code)<BR ALIGN="LEFT"/>+ getClientList()/...List() : list<BR ALIGN="LEFT"/>+ clear()<BR ALIGN="LEFT"/></TD></TR>
        </TABLE>>];

    TravelCompany_ext [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
          <TR><TD BGCOLOR="#cfe2ff"><B>TravelCompany_ext</B></TD></TR>
          <TR><TD ALIGN="LEFT">- airlineList: airlineList<BR ALIGN="LEFT"/>- touroperatorList: touroperatorList<BR ALIGN="LEFT"/>- managerList: managerList<BR ALIGN="LEFT"/>- paymentList: paymentList<BR ALIGN="LEFT"/></TD></TR>
          <TR><TD ALIGN="LEFT">+ createAirline/...Manager/Payment(...)<BR ALIGN="LEFT"/>+ getAirline/...Manager/Payment(code)<BR ALIGN="LEFT"/>+ getPaymentByPackage(code) : payment<BR ALIGN="LEFT"/></TD></TR>
        </TABLE>>];

    // наследование
    edge [arrowhead=onormal, style=solid, dir=forward];
    clientList       -> entityList;
    routeList        -> entityList;
    travelList       -> entityList;
    airlineList      -> entityList;
    touroperatorList -> entityList;
    managerList      -> entityList;
    paymentList      -> entityList;
    travelList_ext   -> travelList;
    TravelCompany_ext -> TravelCompany;

    // агрегация (ромб у владельца)
    edge [arrowhead=odiamond, style=solid, dir=back];
    TravelCompany     -> clientList;
    TravelCompany     -> routeList;
    TravelCompany     -> travelList;
    TravelCompany_ext -> airlineList;
    TravelCompany_ext -> touroperatorList;
    TravelCompany_ext -> managerList;
    TravelCompany_ext -> paymentList;
}
